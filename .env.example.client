# ═══════════════════════════════════════════════════════════════════════════════
# qDocent — Client Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS
# ──────────────────
# 1. Copy this file to `.env` in the project root:
#       copy .env.example.client .env   (Windows)
#       cp .env.example.client .env    (Linux/Mac)
#
# 2. Fill in the values marked [REQUIRED].
#
# 3. Run the app:
#       docker compose build
#       docker compose up
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Google AI API Key ──────────────────────────────────────────────────────────
#
# [REQUIRED] Your Google Gemini API key.
#
# KEY HANDOFF: When the project is transferred to you as the permanent owner,
# replace this value with your own Google API key obtained from:
#   https://aistudio.google.com/app/apikey
#
# IMPORTANT: Keep this key private. Never share .env or commit it to git.
# The .env file is in .gitignore — it will never be accidentally committed.
#
GOOGLE_API_KEY=

# ── R2R AI Engine ──────────────────────────────────────────────────────────────
# Points the FastAPI backend at the R2R service running inside Docker.
# Do not change this unless you know what you are doing.
R2R_BASE_URL=http://r2r:7272

# ── Database (Postgres + pgvector) ────────────────────────────────────────────
# These credentials are used internally by Docker containers.
# You may change the password for production use.
R2R_POSTGRES_HOST=postgres
R2R_POSTGRES_PORT=5432
R2R_POSTGRES_USER=postgres
R2R_POSTGRES_PASSWORD=postgres
R2R_POSTGRES_DBNAME=postgres

# ── RAGAS Evaluation (optional) ───────────────────────────────────────────────
# Used for automated quality evaluation of AI responses. Not required for
# day-to-day operation — only needed if you run `make eval`.
RAGAS_EVAL_MODEL=gemini-3-flash-preview
RAGAS_EMBEDDING_MODEL=models/gemini-embedding-001

# ── Application Settings ───────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Web UI (Next.js) ───────────────────────────────────────────────────────────
#
# LOCAL DEPLOYMENT (same machine as browser):
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#
# VPS / REMOTE SERVER DEPLOYMENT:
#   [REQUIRED CHANGE] Set this to your server's public IP or domain BEFORE
#   running `docker compose build web`. The URL is baked into the browser bundle
#   at build time — changing it after build requires a rebuild.
#
#   Example: NEXT_PUBLIC_API_URL=http://192.168.1.100:8000
#            NEXT_PUBLIC_API_URL=http://your-domain.com:8000
#
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set after running `make demo-setup` (the script prints this value on completion)
NEXT_PUBLIC_DEMO_NOTEBOOK_ID=

