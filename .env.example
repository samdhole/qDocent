# ── Google API ─────────────────────────────────────────────────────────────────
# Used by: FastAPI service (langchain-google-genai), RAGAS evaluation
# In Docker: docker-compose.yml also passes this as GEMINI_API_KEY to R2R/litellm
GOOGLE_API_KEY=

# ── R2R connection ─────────────────────────────────────────────────────────────
# Local dev mode (`make r2r`): http://localhost:7272
# Docker mode (`docker compose up`): http://r2r:7272  ← uncomment this for Docker
R2R_BASE_URL=http://localhost:7272
#R2R_BASE_URL=http://r2r:7272

# ── R2R Postgres (Docker mode only) ───────────────────────────────────────────
# These match the postgres service in docker-compose.yml.
# Not needed for local dev (`make r2r` uses R2R's built-in backend).
R2R_POSTGRES_HOST=postgres
R2R_POSTGRES_PORT=5432
R2R_POSTGRES_USER=postgres
R2R_POSTGRES_PASSWORD=postgres
R2R_POSTGRES_DBNAME=postgres

# ── RAGAS evaluation ───────────────────────────────────────────────────────────
RAGAS_EVAL_MODEL=gemini-3-flash-preview
RAGAS_EMBEDDING_MODEL=models/gemini-embedding-2

# ── FastAPI service ────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are baked into the JS bundle at `next build` time.
# Change these before running `docker compose build web` or `make web`.
# Local access: http://localhost:8000
# VPS/remote: set to your server IP or domain, e.g. http://192.168.1.100:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Set after running `make demo-setup` (script prints the value on completion)
NEXT_PUBLIC_DEMO_NOTEBOOK_ID=
